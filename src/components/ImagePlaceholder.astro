---
interface Props {
	ratio?: '16/9' | '3/2' | '4/3' | '1/1';
	class?: string;
}

const { ratio = '3/2', class: className } = Astro.props;
---

<div class:list={['img-placeholder', className]} style={`aspect-ratio: ${ratio};`}></div>

<style>
	.img-placeholder {
		width: 100%;
		background-color: var(--bg-tertiary);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		position: relative;
		overflow: hidden;
	}

	/* Diagonal line: top-left → bottom-right */
	.img-placeholder::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom right,
			transparent calc(50% - 0.5px),
			var(--border) calc(50% - 0.5px),
			var(--border) calc(50% + 0.5px),
			transparent calc(50% + 0.5px)
		);
	}

	/* Diagonal line: top-right → bottom-left */
	.img-placeholder::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom left,
			transparent calc(50% - 0.5px),
			var(--border) calc(50% - 0.5px),
			var(--border) calc(50% + 0.5px),
			transparent calc(50% + 0.5px)
		);
	}
</style>
