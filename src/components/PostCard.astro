---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category } = post.data;
---

<article class="post-card">
	<a href={`/blog/${post.id}/`} class="card-overlay-link" tabindex="-1" aria-hidden="true"></a>

	<div class="card-content">
		<div class="card-meta">
			<span class:list={['cat-label', `cat-${category}`]}>
				[{category}]
			</span>
			<span class="meta-sep" aria-hidden="true">·</span>
			<FormattedDate date={pubDate} />
		</div>
		<h2 class="card-title">
			<a href={`/blog/${post.id}/`}>{title}</a>
		</h2>
		<p class="card-description">{description}</p>
	</div>
</article>

<style>
	.post-card {
		position: relative;
		background-color: var(--bg-secondary);
		border: 1px solid var(--border);
		border-left: 2px solid transparent;
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition:
			background-color 150ms ease,
			border-left-color 150ms ease,
			transform 150ms ease-out;
	}

	@media (prefers-reduced-motion: no-preference) {
		.post-card:hover {
			background-color: var(--bg-elevated);
			border-left-color: var(--accent);
			transform: translateY(-1px);
		}
	}

	.post-card:not(:hover):not(:focus-within) {
		border-left-color: transparent;
	}

	.card-overlay-link {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.card-content {
		position: relative;
		z-index: 1;
		padding: var(--space-5) var(--space-6) var(--space-6);
	}

	/* ---- Meta row ---- */

	.card-meta {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		margin-bottom: var(--space-3);
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	.cat-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.01em;
	}

	.meta-sep {
		color: var(--text-muted);
	}

	/* Category text colors only — no backgrounds */
	.cat-tutorial { color: var(--accent); }
	.cat-opinion  { color: var(--cat-opinion); }
	.cat-news     { color: var(--cat-news); }
	.cat-analysis { color: var(--cat-analysis); }

	/* ---- Title ---- */

	.card-title {
		font-family: var(--font-sans);
		font-size: var(--text-2xl);
		font-weight: 600;
		line-height: 1.15;
		margin: 0 0 var(--space-3);
	}

	.card-title a {
		color: var(--text-primary);
		text-decoration: none;
		transition: color 150ms ease;
	}

	.card-title a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	/* ---- Description ---- */

	.card-description {
		font-family: var(--font-serif);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
