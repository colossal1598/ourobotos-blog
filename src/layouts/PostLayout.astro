---
import type { CollectionEntry } from 'astro:content';
import AISummary from '../components/AISummary.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgress from '../components/ReadingProgress.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: number;
	ogImage?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	category,
	tags = [],
	summary,
	keyPoints,
	readingTime = 5,
	ogImage,
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} — ourobotos`} description={description} ogImage={ogImage} />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to content</a>
		<ReadingProgress />
		<Header />
		<main id="main-content">
			<article class="post-article">
				<header class="post-header">
					<div class="post-meta-top">
						<span class:list={['cat-label', `cat-${category}`]}>
							[{category}]
						</span>
						<span class="meta-sep" aria-hidden="true">·</span>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<>
									<span class="meta-sep" aria-hidden="true">·</span>
									<span class="updated">
										Updated <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
						<span class="meta-sep" aria-hidden="true">·</span>
						<span class="reading-time">{readingTime} min read</span>
					</div>
					<h1 class="post-title">{title}</h1>
				</header>

			{
				summary && keyPoints && keyPoints.length > 0 && (
					<AISummary
						summary={summary}
						keyPoints={keyPoints}
						readingTime={readingTime}
					/>
				)
			}

				<div class="prose">
					<slot />
				</div>

				<footer class="post-footer">
					<hr class="post-divider" />
					<div class="post-meta-footer">
						<span class:list={['cat-label', `cat-${category}`]}>
							[{category}]
						</span>
						{
							tags.length > 0 && (
								<div class="post-tag-list" aria-label="Post tags">
									{tags.map((tag) => (
										<span class="tag">#{tag}</span>
									))}
								</div>
							)
						}
					</div>
					<NewsletterSignup variant="inline" />
					<p class="byline">Written by Eyal</p>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: var(--space-16) var(--space-6) 0;
	}

	.post-article {
		max-width: 680px;
		margin: 0 auto;
	}

	/* ---- Post Header ---- */

	.post-header {
		margin-bottom: var(--space-8);
	}

	.post-meta-top {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-2);
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-bottom: var(--space-5);
	}

	/* ---- Category bracket label ---- */

	.cat-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.01em;
	}

	/* Category text colors */
	.cat-tutorial { color: var(--accent); }
	.cat-opinion  { color: var(--cat-opinion); }
	.cat-news     { color: var(--cat-news); }
	.cat-analysis { color: var(--cat-analysis); }

	.meta-sep {
		color: var(--text-muted);
	}

	.reading-time {
		font-family: var(--font-mono);
	}

	.updated {
		font-style: italic;
	}

	.post-title {
		font-family: var(--font-sans);
		font-size: var(--text-5xl);
		font-weight: 700;
		line-height: 1.1;
		color: var(--text-primary);
		letter-spacing: -0.02em;
	}

	/* ---- Post Footer ---- */

	.post-footer {
		margin-top: var(--space-16);
	}

	.post-divider {
		border: none;
		border-top: 1px solid var(--border);
		margin: 0 0 var(--space-8);
	}

	.post-meta-footer {
		display: flex;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-bottom: var(--space-8);
	}

	.post-tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}

	.tag {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-muted);
	}

	.byline {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-top: var(--space-8);
		text-align: center;
	}

	/* ---- Responsive ---- */

	@media (max-width: 768px) {
		.post-title {
			font-size: var(--text-4xl);
		}
	}

	@media (max-width: 480px) {
		main {
			padding: var(--space-10) var(--space-4) 0;
		}

		.post-title {
			font-size: var(--text-3xl);
		}
	}
</style>
