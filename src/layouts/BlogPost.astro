---
import type { CollectionEntry } from 'astro:content';
import AISummaryBox from '../components/AISummaryBox.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ReadingProgressBar from '../components/ReadingProgressBar.astro';

interface Props extends CollectionEntry<'blog'>['data'] {
	readingTime?: number;
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	category,
	summary,
	keyPoints,
	readingTime = 5,
} = Astro.props;

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} — ouroboros`} description={description} />
	</head>
	<body>
		<ReadingProgressBar />
		<Header />
		<main>
			<article class="post-article">
				<header class="post-header">
					<div class="post-meta-top">
						<span class:list={['cat-label', `cat-${category}`]}>
							[{category}]
						</span>
						<span class="meta-sep" aria-hidden="true">·</span>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<>
									<span class="meta-sep" aria-hidden="true">·</span>
									<span class="updated">
										Updated <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
						<span class="meta-sep" aria-hidden="true">·</span>
						<span class="reading-time">{readingTime} min read</span>
					</div>
					<h1 class="post-title">{title}</h1>
				</header>

				{
					summary && keyPoints && keyPoints.length > 0 && (
						<div class="summary-wrapper">
							<AISummaryBox
								summary={summary}
								keyPoints={keyPoints}
								readingTime={readingTime}
							/>
						</div>
					)
				}

				<div class="prose">
					<slot />
				</div>

				<footer class="post-footer">
					<hr class="post-divider" />
					<div class="post-tags">
						<span class:list={['cat-label', `cat-${category}`]}>
							[{category}]
						</span>
					</div>
					<NewsletterSignup variant="inline" />
					<p class="byline">Written by Eyal</p>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding: var(--space-16) var(--space-6) 0;
	}

	.post-article {
		max-width: 740px;
		margin: 0 auto;
	}

	/* ---- Post Header ---- */

	.post-header {
		margin-bottom: var(--space-8);
	}

	.post-meta-top {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-2);
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-bottom: var(--space-5);
	}

	/* ---- Category bracket label ---- */

	.cat-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.01em;
	}

	/* Category text colors — dark mode */
	.cat-tutorial { color: var(--accent); }
	.cat-opinion  { color: #c9900c; }
	.cat-news     { color: #4caf50; }
	.cat-analysis { color: #d4a843; }

	/* Category text colors — light mode */
	:global(html[data-theme="light"]) .cat-opinion  { color: #7a4f0d; }
	:global(html[data-theme="light"]) .cat-news     { color: #1e6b21; }
	:global(html[data-theme="light"]) .cat-analysis { color: #6b4f0a; }

	.meta-sep {
		color: var(--text-muted);
	}

	.reading-time {
		font-family: var(--font-mono);
	}

	.updated {
		font-style: italic;
	}

	.post-title {
		font-family: var(--font-sans);
		font-size: var(--text-5xl);
		font-weight: 700;
		line-height: 1.1;
		color: var(--text-primary);
		letter-spacing: -0.02em;
	}

	/* ---- Summary wrapper (constrains to prose width) ---- */

	.summary-wrapper {
		max-width: 680px;
		margin: 0 auto;
	}

	/* ---- Post Footer ---- */

	.post-footer {
		max-width: 680px;
		margin: var(--space-16) auto 0;
	}

	.post-divider {
		border: none;
		border-top: 1px solid var(--border);
		margin: 0 0 var(--space-8);
	}

	.post-tags {
		margin-bottom: var(--space-8);
	}

	.byline {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-muted);
		margin-top: var(--space-8);
		text-align: center;
	}

	/* ---- Responsive ---- */

	@media (max-width: 768px) {
		.post-title {
			font-size: var(--text-4xl);
		}
	}

	@media (max-width: 480px) {
		main {
			padding: var(--space-10) var(--space-4) 0;
		}

		.post-title {
			font-size: var(--text-3xl);
		}
	}
</style>
