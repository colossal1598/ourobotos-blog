---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Use frontmatter readingTime if set, otherwise approximate from word count
const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = post.data.readingTime ?? Math.max(1, Math.ceil(wordCount / 200));
const ogImage = `/og/${post.id}.png`;
---

<PostLayout {...post.data} readingTime={readingTime} ogImage={ogImage}>
	<Content />
</PostLayout>
