---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Prefer explicitly featured post; fall back to most recent
const featuredPost = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const rest = allPosts.filter((p) => p.id !== featuredPost?.id);
const secondary = rest.slice(0, 4);

// Use frontmatter readingTime if set, otherwise approximate
const featuredWordCount = featuredPost?.body?.split(/\s+/).filter(Boolean).length ?? 0;
const featuredReadingTime =
	featuredPost?.data.readingTime ?? Math.max(1, Math.ceil(featuredWordCount / 200));
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main id="main-content">
		<!-- Masthead -->
		<section class="masthead">
			<h1 class="site-title">ourobotos</h1>
			<p class="site-tagline">
				<em>Writing at the intersection of technology and thought.</em>
			</p>
		</section>

		<!-- Featured post hero -->
		{
			featuredPost && (
				<section class="hero">
					<div class="hero-meta">
						<span class:list={['cat-label', `cat-${featuredPost.data.category}`]}>
							[{featuredPost.data.category}]
						</span>
						<span class="meta-sep" aria-hidden="true">·</span>
						<FormattedDate date={featuredPost.data.pubDate} />
						<span class="meta-sep" aria-hidden="true">·</span>
						<span class="reading-time">{featuredReadingTime} min read</span>
					</div>

					<h2 class="hero-title">
						<a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
					</h2>

					<p class="hero-description">{featuredPost.data.description}</p>

					{featuredPost.data.summary && (
						<p class="hero-excerpt">{featuredPost.data.summary}</p>
					)}

					<a href={`/blog/${featuredPost.id}/`} class="continue-reading">
						Continue reading →
					</a>
				</section>
			)
		}

		<!-- Secondary posts grid -->
		{
			secondary.length > 0 && (
				<section class="secondary-grid">
					{secondary.map((post) => (
						<PostCard post={post} />
					))}
				</section>
			)
		}

		<!-- Newsletter CTA -->
		<section class="newsletter-section">
			<NewsletterSignup />
		</section>
	</main>
</BaseLayout>

<style>
	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: var(--space-16) var(--space-6) 0;
	}

	/* ---- Masthead ---- */

	.masthead {
		margin-bottom: var(--space-16);
	}

	.site-title {
		font-family: var(--font-sans);
		font-size: var(--text-6xl);
		font-weight: 700;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--text-primary);
		margin: 0 0 var(--space-4);
	}

	.site-tagline {
		font-family: var(--font-serif);
		font-size: var(--text-lg);
		color: var(--text-secondary);
		margin: 0;
		font-style: italic;
	}

	/* ---- Hero ---- */

	.hero {
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		padding: var(--space-12) 0;
		margin-bottom: var(--space-12);
	}

	/* ---- Hero meta ---- */

	.hero-meta {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-sans);
		font-size: var(--text-xs);
		color: var(--text-muted);
		margin-bottom: var(--space-5);
	}

	.cat-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		letter-spacing: 0.01em;
	}

	.meta-sep {
		color: var(--text-muted);
	}

	.reading-time {
		font-family: var(--font-mono);
	}

	/* Category text colors */
	.cat-tutorial { color: var(--accent); }
	.cat-opinion  { color: var(--cat-opinion); }
	.cat-news     { color: var(--cat-news); }
	.cat-analysis { color: var(--cat-analysis); }

	.hero-title {
		font-family: var(--font-sans);
		font-size: var(--text-5xl);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		margin: 0 0 var(--space-6);
		max-width: 820px;
	}

	.hero-title a {
		color: inherit;
		text-decoration: none;
		transition: color 150ms ease;
	}

	.hero-title a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.hero-description {
		font-family: var(--font-serif);
		font-size: var(--text-base);
		color: var(--text-secondary);
		line-height: 1.7;
		margin: 0 0 var(--space-4);
	}

	.hero-excerpt {
		font-family: var(--font-serif);
		font-size: var(--text-sm);
		color: var(--text-muted);
		line-height: 1.7;
		margin: 0 0 var(--space-8);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.continue-reading {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		padding-bottom: 1px;
		transition:
			color 150ms ease,
			border-bottom-color 150ms ease;
	}

	.continue-reading:hover {
		color: var(--accent-hover);
		border-bottom-color: var(--accent-hover);
		text-decoration: none;
	}

	/* ---- Secondary grid ---- */

	.secondary-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-5);
		margin-bottom: var(--space-16);
	}

	/* ---- Newsletter ---- */

	.newsletter-section {
		margin-bottom: var(--space-20);
	}

	/* ---- Responsive ---- */

	@media (max-width: 640px) {
		.site-title {
			font-size: var(--text-5xl);
		}

		.hero-title {
			font-size: var(--text-4xl);
		}

		.secondary-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		main {
			padding: var(--space-10) var(--space-4) 0;
		}

		.site-title {
			font-size: var(--text-4xl);
		}

		.hero-title {
			font-size: var(--text-3xl);
		}
	}
</style>
